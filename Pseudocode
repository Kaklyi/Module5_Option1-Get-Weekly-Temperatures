START

// Create list of days in the week
SET days = [Monday, Tuesday, Wednesday, Thursday, Friday, Saturday, Sunday]

// Create empty list to store temperatures
SET temps = empty list

// Collect temperatures for each day
FOR each day IN days
    DISPLAY "Enter temperature for" day
    INPUT temp

    // Validate input
    WHILE input is not a number
        DISPLAY "Please enter a valid number"
        INPUT temp
    END WHILE

    // Store temperature
    ADD temp TO temps
END FOR

// Ask user what information they want to see
WHILE TRUE

    DISPLAY "Enter a day, 'week' to see all temperatures, or 'done' to exit"
    INPUT choice

    IF choice = "done"
        DISPLAY "All done"
        EXIT LOOP
    END IF

    // Show all temperatures and weekly average
    IF choice = "week"
        SET total = 0

        FOR each index i in days
            DISPLAY days[i] and temps[i]
            SET total = total + temps[i]
        END FOR

        SET average = total / number of days
        DISPLAY average

    ELSE

        // Check if entered day exists
        IF day exists in days
            FIND index of day
            DISPLAY corresponding temperature
        ELSE
            DISPLAY "Invalid day"
        END IF

    END IF

END WHILE

END
